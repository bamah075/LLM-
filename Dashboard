      <tr><th colspan="2">Analysis</th></tr>
      <tr><td>Monthly savings</td><td><strong style="color:${savings>0?'var(--green)':'var(--red)'}">$${Math.abs(savings).toFixed(0)}/mo ${savings>0?'saved':'more expensive'}</strong></td></tr>
