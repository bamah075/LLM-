import hashlib, chromadb

def upsert_document(collection, doc_id, content, metadata):
    new_hash = hashlib.sha256(content.encode()).hexdigest()
    existing = collection.get(where={"doc_id": doc_id}, include=["metadatas"])

    if existing["metadatas"] and existing["metadatas"][0].get("hash") == new_hash:
        return  # unchanged, skip

    # Delete old chunks for this doc
    collection.delete(where={"doc_id": doc_id})

    # Re-chunk and re-embed
    chunks = chunk_text(content, size=512, overlap=128)
    embeddings = embed(chunks)  # your embedding model

    collection.upsert(
        ids=[f"{doc_id}_{i}" for i in range(len(chunks))],
        documents=chunks,
        embeddings=embeddings,
        metadatas=[{**metadata, "doc_id": doc_id, "hash": new_hash, "chunk": i}
                   for i in range(len(chunks))]
    )</code></pre>
