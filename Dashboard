    <pre style="margin-top:20px"><code>import asyncio, time

async def query_with_fallback(prompt, is_sensitive=True):
    chain = [
        {"model": "qwen3:72b",    "timeout": 8.0, "min_quality": 0.8},
        {"model": "qwen3:7b",     "timeout": 3.0, "min_quality": 0.5},
        {"model": "gpt-4o-mini",  "timeout": 5.0, "min_quality": 0.0, "cloud": True},
    ]

    for step in chain:
        if step.get("cloud") and is_sensitive:
            continue  # never send sensitive data to cloud
        try:
            response = await asyncio.wait_for(
                call_model(step["model"], prompt),
                timeout=step["timeout"]
            )
            quality = score_response(response)
            if quality >= step["min_quality"]:
                return {"response": response, "model": step["model"], "fallback_used": step != chain[0]}
        except (asyncio.TimeoutError, RuntimeError) as e:
            log_fallback_event(step["model"], str(e))
            continue  # try next in chain

    return {"response": "Service temporarily unavailable. Please try again.", "error": True}</code></pre>
