// Scorecard
function calcScore() {
  const boxes = document.querySelectorAll('#scorecard-items input[type=checkbox]');
  const checked = Array.from(boxes).filter(b => b.checked).length;
  const result = document.getElementById('scorecard-result');
  if(checked === 0) { result.innerHTML = 'Tick the boxes above to get your personalised recommendation.'; result.style.color='var(--muted)'; return; }

  let msg = '', color = '';
  if(checked >= 6) {
    color = 'var(--green)';
    msg = '✅ <strong>Strong case for Local LLM.</strong> You have the use case, budget intent, and technical access. Prioritise: hardware ($3,000–$8,000), connect your documents (RAG), and build a 50-question test suite before going live. Start with Qwen 3 72B if budget allows, or Llama 3.3 8B for a smaller start.';
  } else if(checked >= 4) {
    color = 'var(--yellow)';
    msg = '⚠️ <strong>Likely a good fit, but address your gaps first.</strong> Check which boxes you didn\'t tick — those are your barriers. If you lack technical staff, budget to outsource setup. If budget is tight, start with cloud AI for 3 months to prove value, then invest in local hardware.';
  } else if(checked >= 2) {
    color = 'var(--orange)';
    msg = '🔶 <strong>Cloud AI first, local later.</strong> You have some reasons to go local, but not enough to justify the setup cost and complexity today. Use ChatGPT or Claude API for 6 months. When your usage grows or data sensitivity increases, revisit local LLM.';
  } else {
    color = 'var(--red)';
    msg = '❌ <strong>Not ready for local LLM yet.</strong> Cloud API (ChatGPT, Claude) is the right starting point. Local LLM requires either heavy usage, sensitive data, or a specific customisation need — and you\'ve indicated none of those apply strongly right now.';
  }
  result.innerHTML = msg;
  result.style.color = color;
}

