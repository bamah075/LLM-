      <tr><td>Total VRAM needed</td><td><strong>${totalNeeded.toFixed(1)}GB</strong></td></tr>
      <tr><td>Your VRAM</td><td><strong>${vram}GB</strong></td></tr>
      <tr><td>Offload to system RAM</td><td><strong>${offload.toFixed(1)}GB</strong></td></tr>
      <tr><td>Estimated speed</td><td><strong style="color:var(--${status==='green'?'green':status==='yellow'?'yellow':'red'})">${speedEst > 0 ? speedEst + ' t/s' : 'Cannot run'}</strong></td></tr>
