    <pre><code>class ConversationManager:
    def __init__(self, model, max_tokens=8192, summary_threshold=0.7):
        self.model = model
        self.max_tokens = max_tokens
        self.summary_threshold = summary_threshold  # compress at 70% full
        self.messages = []
        self.summary = ""

    def add_turn(self, role, content):
        self.messages.append({"role": role, "content": content})

        current_tokens = count_tokens(self.messages)
        if current_tokens > self.max_tokens * self.summary_threshold:
            self._compress()

    def _compress(self):
        # Keep last 3 exchanges (6 messages) + summarize the rest
        recent = self.messages[-6:]
        to_summarize = self.messages[:-6]

        summary_prompt = f"""Previous summary: {self.summary}

New conversation to summarize:
{format_messages(to_summarize)}

Write a concise summary preserving: key facts, decisions made, user preferences, open questions."""

        new_summary = llm(summary_prompt, max_tokens=400)
        self.summary = new_summary

        # Rebuild: system context + summary + recent turns
        self.messages = [
            {"role": "system", "content": f"Context from earlier: {self.summary}"},
            *recent
        ]

    def get_messages_for_inference(self):
        return self.messages</code></pre>
