from openai import OpenAI  # use with local Ollama endpoint

client = OpenAI(base_url="http://localhost:11434/v1", api_key="ollama")

def run_eval(model, test_cases, judge_model="qwen3:72b"):
    results = []
    for case in test_cases:
        start = time.time()
        response = client.chat.completions.create(
            model=model,
            messages=[{"role":"user","content": case["input"]}]
        )
        latency = time.time() - start
        output = response.choices[0].message.content

        # Score with LLM judge
        score = judge(judge_model, case["input"], output, case["expected"])
        results.append({"case": case["id"], "latency": latency, "score": score})

    accuracy = sum(r["score"] for r in results) / len(results)
    avg_latency = sum(r["latency"] for r in results) / len(results)
    return {"model": model, "accuracy": accuracy, "avg_latency": avg_latency}

def judge(judge_model, question, answer, expected):
    prompt = f"""Rate this answer 0-1 (1=correct, 0=wrong).
Question: {question}
Expected: {expected}
Answer: {answer}
Return only a number between 0 and 1."""
    response = client.chat.completions.create(
        model=judge_model,
        messages=[{"role":"user","content": prompt}]
    )
    try: return float(response.choices[0].message.content.strip())
    except: return 0.5</code></pre>
