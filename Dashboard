// Hardware calculator
function calcHardware() {
  const [params, baseGB] = document.getElementById('hw-model').value.split(',').map(Number);
  const quantMult = parseFloat(document.getElementById('hw-quant').value);
  const ctx = parseFloat(document.getElementById('hw-ctx').value);
  const vram = parseFloat(document.getElementById('hw-vram').value);
  const ram = parseFloat(document.getElementById('hw-ram').value);

  const modelGB = baseGB * quantMult;
  const kvCache = params * 0.001 * ctx * 2; // rough KV cache estimate
  const totalNeeded = modelGB + kvCache;
  const offload = Math.max(0, totalNeeded - vram);
  const inVRAM = Math.min(totalNeeded, vram);
  const canRun = inVRAM + ram >= totalNeeded;

  let speedEst = 0;
  if(vram >= totalNeeded) speedEst = Math.round(120 / (params / 7));
  else if(canRun) speedEst = Math.round(30 / (params / 7));
  else speedEst = 0;

  const status = vram >= totalNeeded ? 'green' : canRun ? 'yellow' : 'red';
  const statusText = vram >= totalNeeded ? '✅ Fits fully in VRAM' : canRun ? '⚠️ Partial GPU offload needed' : '❌ Cannot run — needs more hardware';

  document.getElementById('hw-output').innerHTML = `
