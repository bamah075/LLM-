    <div class="card-title">Citation Verification Pipeline</div>
    <pre><code>def verify_with_citations(query, retrieved_chunks, model_answer):
    """
    1. Ask model to answer WITH citations (chunk IDs)
    2. Verify every claim appears in cited chunk
    3. Flag or suppress uncited claims
    """
    # Step 1: Structured prompt forcing citations
    prompt = f"""Answer using ONLY the provided context.
For every fact, cite the chunk ID like [chunk_1].
If the answer is not in the context, say "I don't know".

Context:
{format_chunks(retrieved_chunks)}

Question: {query}"""

    answer = llm(prompt)

    # Step 2: Extract citations from answer
    cited_ids = re.findall(r'\[chunk_(\d+)\]', answer)

    # Step 3: Check every sentence has a citation
    sentences = split_sentences(answer)
    uncited = [s for s in sentences if not re.search(r'\[chunk_\d+\]', s)
               and not is_connector(s)]  # ignore "therefore", "however" etc.

    # Step 4: Verify cited content supports the claim
    hallucination_risk = "LOW"
    if len(uncited) > 2 or len(cited_ids) == 0:
        hallucination_risk = "HIGH"

    return {"answer": answer, "uncited_sentences": uncited, "risk": hallucination_risk}</code></pre>
