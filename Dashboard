// Cost calculator
function calcCost() {
  const hw = parseFloat(document.getElementById('cost-hw').value) || 0;
  const life = parseFloat(document.getElementById('cost-life').value) || 3;
  const tokens = parseFloat(document.getElementById('cost-tokens').value) || 0; // M/day
  const elec = parseFloat(document.getElementById('cost-elec').value) || 0;
  const power = parseFloat(document.getElementById('cost-power').value) || 0;
  const cloudPer1M = parseFloat(document.getElementById('cost-cloud').value) || 0;
  const hours = parseFloat(document.getElementById('cost-hours').value) || 0;
  const rate = parseFloat(document.getElementById('cost-rate').value) || 0;

  const hwPerMonth = hw / (life * 12);
  const elecPerMonth = (power / 1000) * 24 * 30 * elec;
  const laborPerMonth = hours * rate;
  const totalLocalPerMonth = hwPerMonth + elecPerMonth + laborPerMonth;

  const cloudPerMonth = tokens * 30 * cloudPer1M;
  const savings = cloudPerMonth - totalLocalPerMonth;
  const breakeven = savings > 0 ? (hw / savings).toFixed(1) : '∞';

  document.getElementById('cost-output').innerHTML = `
